---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
	<section class="relative flex flex-col items-center justify-center min-h-[calc(100svh-80px)] py-12 sm:py-16">
		<div class="page-shell relative z-10 flex items-center justify-center">
			<div class="hero-stack flex flex-col items-center gap-6 sm:gap-8 w-full max-w-[1080px] text-center">
				<div class="flex flex-wrap gap-3 items-center justify-center px-4 py-1 rounded-lg bg-(--color-skyBlue)/30 border-[0.5px] border-(--color-skyBlue)/80">
					<strong class="text-sm text-white">Status</strong>
					<div class="hidden sm:flex items-center justify-center w-[0.5px] h-5 bg-(--color-skyBlue)/80"></div>
					<span class="text-sm sm:text-base">Continuously Seeking</span>
				</div>
				<h1 class="hero-title font-geist font-semibold text-white text-balance">
					Building solutions with design and code
				</h1>
				<p class="hero-subtitle text-(--color-Timberwolf) font-geist text-pretty">
					I'm a problem solver with a passion for building solutions that are not only functional, but also intuitive.
				</p>
			</div>
		</div>
	</section>
</MainLayout>

<style>
	/* Fluid type scale: shrinks gracefully on phones and grows up to ultrawide.
	   Uses clamp() so we get a smooth ramp without juggling 5+ breakpoints. */
	.hero-title {
		font-size: clamp(2rem, 1.4rem + 3.2vw, 4.5rem);
		line-height: 1.08;
		letter-spacing: -0.01em;
	}

	.hero-subtitle {
		font-size: clamp(1rem, 0.9rem + 0.6vw, 1.5rem);
		line-height: 1.5;
		max-width: 60ch;
	}

	/* On extra-wide / 4K monitors, allow the headline to grow a bit more
	   without letting line-length blow past readability. */
	@media (min-width: 1920px) {
		.hero-title {
			font-size: clamp(3.5rem, 2.5rem + 2vw, 5.5rem);
		}
	}
</style>