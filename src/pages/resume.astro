---
import MainLayout from '../layouts/MainLayout.astro';
import MarlonAusbyJuniorProfilePicture from '../assets/about/WaterSideHeadshot.png?url';
import { getIconWithColor, iconMap } from '../config/icons';

const skyBlue = '#69d7f2';
---

<MainLayout>
	<!-- <MainMenu /> -->

	<section class="relative flex flex-col items-center w-full">
		<div class="page-shell relative z-10 w-full max-w-[1080px] flex flex-col md:flex-row items-start justify-center gap-8 py-8 md:py-12">
			<!-- Description Section -->
			<div class="flex flex-col items-start w-full md:w-2/3 gap-6 md:gap-8 md:p-4">
				<!-- Name and Title -->
				<div class="relative flex flex-col gap-3">
					<h1 class="about-title font-medium leading-none">
						Marlon Ausby II
					</h1>
					<h2 class="about-subtitle font-light text-(--color-gray)">
						Solutions Engineer
					</h2>
				</div>
				<!-- Summary -->
				<div class="flex flex-col mb-10">
					<p class="text-base sm:text-lg text-(--color-platinum) max-w-[65ch]">
						With 6+ years of experience building secure, data-driven systems in fintech and cloud environments.
						Specialized in payment processing, PCI-compliant architectures, large-scale data migrations, and fraud detection.
						Background in biomedical sciences brings a rigorous, analytical approach to designing reliable, scalable applications.
					</p>
				</div>
				<!-- Experience -->
				<div class="skill-accordion">
					<h3 class="sub-heading">Experience</h3>
					<!-- My Well -->
					<div class="skill-bullet mt-6">
						<div class="flex flex-row justify-between">
							<h4 class="leading-none text-[1.5em] text-(--color-platinum) font-medium">
								My Well
							</h4>
							<p class="sub-description">
								Remote, Chicago, IL
							</p>
						</div>
						<details class="experience-details">
							<summary class="experience-summary">
								<span class="text-(--color-skyBlue) text-sm">CRM Operations Architect</span>
								<span class="flex items-center gap-2 shrink-0">
									<span class="text-(--color-skyBlue)/80 text-sm">2026 - Present</span>
									<span class="experience-chevron w-4 h-4 flex shrink-0" set:html={getIconWithColor('chevron-right', skyBlue)} />
								</span>
							</summary>
							<ul class="list-disc flex flex-col gap-3 ps-5 mt-3">
								<li>
									Architected My Well's CRM ecosystem across HubSpot and Notion — designing lifecycle automation, segmentation, and cross-platform integrations spanning Marketing, Sales, Onboarding, and Partner Success.
								</li>
								<li>
									Built executive-level reporting dashboards providing full lifecycle visibility across 500+ client organizations — from lead generation through implementation, retention, and churn indicators.
								</li>
								<li>
									Engineered scalable workflow automation and lead routing systems that reduced manual operational overhead and improved cross-functional alignment across all customer-facing teams.
								</li>
							</ul>
						</details>
						<details class="experience-details">
							<summary class="experience-summary">
								<span class="text-(--color-skyBlue) text-sm">Technical Support Specialist</span>
								<span class="flex items-center gap-2 shrink-0">
									<span class="text-(--color-skyBlue)/80 text-sm">2025 - 2026</span>
									<span class="experience-chevron w-4 h-4 flex shrink-0" set:html={getIconWithColor('chevron-right', skyBlue)} />
								</span>
							</summary>
							<ul class="list-disc flex flex-col gap-3 ps-5 mt-3">
								<li>
									Engineered Python/TypeScript scripts for 40+ PCI compliant, vaulted data
									migrations (100K+ payment methods, 99.3% accuracy).
								</li>
								<li>
									Developed SQL reports and dashboards for 50+ clients and led fraud-detection
									initiatives that blocked over 200K+ suspicious transactions.
								</li>
								<li>
									Built Python and TypeScript tooling to diagnose and resolve virtual POS
									transaction sync failures, improving settlement accuracy and reinforcing
									PCI DSS Level 1 compliance — over $1.3 Billion processed annually.
								</li>
							</ul>
						</details>
						<details class="experience-details">
							<summary class="experience-summary">
								<span class="text-(--color-skyBlue) text-sm">Technical Consultant</span>
								<span class="flex items-center gap-2 shrink-0">
									<span class="text-(--color-skyBlue)/80 text-sm">2021 - 2024</span>
									<span class="experience-chevron w-4 h-4 flex shrink-0" set:html={getIconWithColor('chevron-right', skyBlue)} />
								</span>
							</summary>
							<ul class="list-disc flex flex-col gap-3 ps-5 mt-3">
								<li>
									Engineered sales focused pipelines that details the status and quality of a lead,
									ultimately generating over $300,000 in ARR.
								</li>
								<li>
									Coordinate FinTech architecture and adoption for over 80 organizations annually.
								</li>
								<li>
									Engineered and managed API integrations between Google Sheets, Notion, and
									HubSpot.
								</li>
							</ul>
						</details>
					</div>
					<!-- The 7th Lab -->
					<div class="skill-bullet mt-6">
						<div class="flex flex-row justify-between">
							<h4 class="leading-none text-[1.5em] text-(--color-platinum) font-medium">
								The 7th Lab
							</h4>
							<p class="sub-description">
								Remote, USA
							</p>
						</div>
						<details class="experience-details">
							<summary class="experience-summary">
								<span class="text-(--color-skyBlue) text-sm">Founder & Operator</span>
								<span class="flex items-center gap-2 shrink-0">
									<span class="text-(--color-skyBlue)/80 text-sm">2018 - Present</span>
									<span class="experience-chevron w-4 h-4 flex shrink-0" set:html={getIconWithColor('chevron-right', skyBlue)} />
								</span>
							</summary>
							<ul class="list-disc flex flex-col gap-3 ps-5 mt-3">
								<li>
									Lead cross-functional teams in planning, development, and deployment of 20+
									full-stack projects using modern frameworks (Next.js, React, FastAPI) and
									cloudnative architectures (AWS, Docker).
								</li>
								<li>
									Instituted Agile/DevOps practices (CI/CD, Terraform) to accelerate release
									cycles, achieving quarterly profitable product launches for 5+ years.
								</li>
							</ul>
						</details>
					</div>
					<!-- Vintage Etc. -->
					<div class="skill-bullet mt-6">
						<div class="flex flex-row justify-between">
							<h4 class="leading-none text-[1.5em] text-(--color-platinum) font-medium">
								Vintage Etc.
							</h4>
							<p class="sub-description">
								Tampa, FL
							</p>
						</div>
						<details class="experience-details">
							<summary class="experience-summary">
								<span class="text-(--color-skyBlue) text-sm">Junior Developer & Assistant Store Manager</span>
								<span class="flex items-center gap-2 shrink-0">
									<span class="text-(--color-skyBlue)/80 text-sm">2018 - 2020</span>
									<span class="experience-chevron w-4 h-4 flex shrink-0" set:html={getIconWithColor('chevron-right', skyBlue)} />
								</span>
							</summary>
							<ul class="list-disc flex flex-col gap-3 ps-5 mt-3">
								<li>
									Developed and maintained e-commerce sites (WordPress, Shopify, MySQL, Square),
									cutting load times by 40%.
								</li>
								<li>
									Managed 15+ staff and optimized workflows, boosting efficiency 25%.
								</li>
								<li>
									Automated reports and trained teams, saving 12 hours/week on admin tasks.
								</li>
								<li>
									Achieved sale volume of $600,000+ in second-hand retail.
								</li>
							</ul>
						</details>
					</div>
				</div>
				<!-- Education -->
				<div class="skill-accordion">
					<h3 class="sub-heading">Education</h3>
					<div class="skill-bullet mt-6">
						<div class="flex flex-row justify-between">
							<h4 class="leading-none text-[1.5em] text-(--color-platinum) font-medium">
								University of South Florida
							</h4>
							<p class="sub-description">
								Tampa, FL
							</p>
						</div>
						<details class="experience-details">
							<summary class="experience-summary">
								<span class="text-(--color-skyBlue) text-sm">BS in Biomedical Sciences</span>
								<span class="flex items-center gap-2 shrink-0">
									<span class="text-(--color-skyBlue)/80 text-sm">2016 - 2019</span>
									<span class="experience-chevron w-4 h-4 flex shrink-0" set:html={getIconWithColor('chevron-right', skyBlue)} />
								</span>
							</summary>
							<ul class="list-disc flex flex-col gap-3 ps-5 mt-3">
								<li>
									Applied Python and MySQL to build predictive datasets for biomedical research projects; deployed virtualized environments to support cross-OS spectroscopic software.
								</li>
							</ul>
						</details>
					</div>
				</div>
				<!-- Technical Skills -->
					<div class="skill-accordion">
						<h3 class="sub-heading">Technical Skills</h3>
						<!-- Languages -->
						<div class="skill-bullet mt-6">
							<h4 class="leading-none text-[1.5em] text-(--color-platinum) font-medium">
								Languages
							</h4>
							<p class="sub-description">
								Building applications and solving problems with:
							</p>
							<div class="flex gap-2">
								<div class="skill-tab">
									<span class="w-3 h-3 flex shrink-0" set:html={getIconWithColor('javascript', skyBlue)} />
									JavaScript
								</div>
								<div class="skill-tab">
									<span class="w-3 h-3 flex shrink-0" set:html={getIconWithColor('typescript', skyBlue)} />
									TypeScript
								</div>
								<div class="skill-tab">
									<span class="w-5 h-5 flex shrink-0" set:html={getIconWithColor('python', skyBlue)} />
									Python
								</div>
								<div class="skill-tab">
									<span class="w-6 h-6 flex shrink-0" set:html={getIconWithColor('go', skyBlue)} />
									Go
								</div>
							</div>
							<div class="flex gap-2">
								<div class="skill-tab">
									<span class="w-5 h-5 flex shrink-0" set:html={getIconWithColor('sql', skyBlue)} />
									SQL
								</div>
								<div class="skill-tab">
									<span class="w-5 h-5 flex shrink-0" set:html={getIconWithColor('html5', skyBlue)} />
									HTML
								</div>
								<div class="skill-tab">
									<span class="w-6 h-6 flex shrink-0" set:html={getIconWithColor('css3', skyBlue)} />
									CSS
								</div>
							</div>
						</div>
						<!-- Frameworks -->
						<div class="skill-bullet">
							<h4 class="leading-none text-[1.5em] text-(--color-platinum) font-medium">
								Frameworks
							</h4>
							<p class="sub-description">
								Streamlining development with:
							</p>
							<div class="flex gap-2">
								<div class="skill-tab">
									<span class="w-4 h-4 flex shrink-0" set:html={getIconWithColor('nextjs', skyBlue)} />
									Next.js
								</div>
								<div class="skill-tab">
									<span class="w-5 h-5 flex shrink-0" set:html={getIconWithColor('react', skyBlue)} />
									React
								</div>
								<div class="skill-tab">
									<span class="w-5 h-5 flex shrink-0" set:html={getIconWithColor('flutter', skyBlue)} />
									Flutter
								</div>
								<div class="skill-tab">
									<span class="w-5 h-5 flex shrink-0" set:html={getIconWithColor('astro', skyBlue)} />
									Astro.js
								</div>
							</div>
							<div class="flex gap-2">
								<div class="skill-tab">
									<span class="w-4 h-4 flex shrink-0" set:html={getIconWithColor('tailwind', skyBlue)} />
									Tailwind
								</div>
							</div>
						</div>
						<!-- Databases -->
						<div class="skill-bullet">
							<h4 class="leading-none text-[1.5em] text-(--color-platinum) font-medium">
								Databases
							</h4>
							<p class="sub-description">
								Storing and querying data with:
							</p>
							<div class="flex gap-2">
								<div class="skill-tab">
									<span class="w-5 h-5 flex shrink-0" set:html={getIconWithColor('mysql', skyBlue)} />
									MySQL
								</div>
								<div class="skill-tab">
									<span class="w-5 h-5 flex shrink-0" set:html={iconMap['postgresql']} />
									PostgreSQL
								</div>
								<div class="skill-tab">
									<span class="w-5 h-5 flex shrink-0" set:html={getIconWithColor('supabase', skyBlue)} />
									Supabase
								</div>
							</div>
						</div>
						<!-- Cloud & DevOps -->
						<div class="skill-bullet">
							<h4 class="leading-none text-[1.5em] text-(--color-platinum) font-medium">
								Cloud & DevOps
							</h4>
							<p class="sub-description">
								Launching and managing applications in:
							</p>
							<div class="flex gap-2">
								<div class="skill-tab">
									<span class="w-5 h-5 flex shrink-0" set:html={getIconWithColor('aws', skyBlue)} />
									AWS
								</div>
								<div class="skill-tab">
									<span class="w-5 h-5 flex shrink-0" set:html={getIconWithColor('docker', skyBlue)} />
									Docker
								</div>
								<div class="skill-tab">
									<span class="w-4 h-4 flex shrink-0" set:html={getIconWithColor('proxmox', skyBlue)} />
									Proxmox
								</div>
							</div>
						</div>
						<!-- Payments & Security -->
						<div class="skill-bullet">
							<h4 class="leading-none text-[1.5em] text-(--color-platinum) font-medium">
								Payments & Securities
							</h4>
							<p class="sub-description">
								Processing payments and ensuring security with:
							</p>
							<div class="flex gap-2">
								<div class="skill-tab">
									<span class="w-4 h-4 flex shrink-0" set:html={getIconWithColor('stripe', skyBlue)} />
									Stripe
								</div>
								<div class="skill-tab">
									<span class="w-4 h-4 flex shrink-0" set:html={getIconWithColor('shield', skyBlue)} />
									PCI 1
								</div>
								<div class="skill-tab">
									<span class="w-4 h-4 flex shrink-0" set:html={getIconWithColor('vaulted-data', skyBlue)} />
									Vaulted Data
								</div>
							</div>
						</div>
				</div>
			</div>
		</div>
	</section>

	<!-- <FooterMenu /> -->
</MainLayout>

<style>
	.social-button {
		cursor: pointer;
		position: relative;
		display: flex;
		align-items: center;
		font-size: 0.875rem;
		line-height: 1.25rem;
		padding: 0.25rem 0.75rem;
		background-color: black;
		border: 2px solid color-mix(in srgb, var(--color-skyBlue) 20%, transparent);
		border-radius: 9999px;
		gap: 0.25rem;
		transition:
			border-color 200ms,
			color 200ms,
			background-color 200ms;
	}

	.social-button:hover {
		border-color: var(--color-skyBlue);
	}

	/* Profile picture: smaller on phones, grows on tablet+ */
	.profile-img {
		width: clamp(6rem, 8rem + 4vw, 11rem);
	}

	/* Fluid headings on About */
	.about-title {
		font-size: clamp(2rem, 1.4rem + 3vw, 4rem);
	}
	.about-subtitle {
		font-size: clamp(1.125rem, 0.9rem + 1.2vw, 2rem);
	}
	.skill-accordion {
		display: flex;
		flex-direction: column;
		width: 100%;
		padding-inline: 1rem;
		padding-block: 0.25rem;
		border-radius: 0.5rem;
		background-color: black;
		border: 2px solid color-mix(in srgb, var(--color-skyBlue) 40%, transparent);
		transition: border-color 200ms, color 200ms, background-color 200ms;
	}

	.skill-accordion:hover {
		border-color: var(--color-skyBlue);
	}

	.skill-tab {
		position: relative;
		display: flex;
		align-items: center;
		font-size: 0.875rem;
		line-height: 1.25rem;
		padding: 0.25rem 0.75rem;
		background-color: black;
		border: 1px solid color-mix(in srgb, var(--color-skyBlue) 20%, transparent);
		border-radius: 5px;
		gap: 0.3rem;
		transition: border-color 200ms, color 200ms, background-color 200ms;
	}

	.skill-bullet {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		margin-bottom: 1.5rem;
	}

	.sub-heading {
		font-size: 2.5em;
		font-weight: 400;
	}

	.sub-description {
		color: var(--color-gray);
	}

	.experience-details {
		border-top: 1px solid color-mix(in srgb, var(--color-skyBlue) 15%, transparent);
		padding-top: 0.5rem;
	}

	.experience-details:first-of-type {
		margin-top: 0.25rem;
	}

	.experience-summary {
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		cursor: pointer;
		list-style: none;
		padding-block: 0.25rem;
		transition: color 200ms;
	}

	.experience-summary::-webkit-details-marker {
		display: none;
	}

	.experience-summary:hover {
		color: var(--color-skyBlue);
	}

	.experience-chevron {
		transition: transform 200ms ease;
	}

	.experience-details[open] .experience-chevron {
		transform: rotate(90deg);
	}
</style>