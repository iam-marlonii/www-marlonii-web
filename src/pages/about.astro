---
import MainLayout from '../layouts/MainLayout.astro';
import { getIconWithColor, iconMap } from '../config/icons';

const skyBlue = '#69d7f2';
---

<MainLayout>
	<!-- <MainMenu /> -->

	<section class="relative flex flex-col items-center w-full">
		<div class="page-shell relative z-10 w-full max-w-[1080px] flex flex-col md:flex-row items-start justify-center gap-8 py-8 md:py-12">
			<!-- Picture, Location, and Languages -->
			<aside class="md:sticky md:top-[96px] flex flex-row md:flex-col items-center md:items-center justify-center w-full md:w-1/3 shrink-0 gap-4 md:p-4">
				<img
					src="https://storage.marlonii.com/headshots/WaterSideHeadshot.png"
					alt="Marlon Ausby Junior Profile Picture"
					class="profile-img h-auto rounded-full border border-(--color-skyBlue)/40"
				/>
				<div class="flex flex-col items-start md:items-center gap-2 md:gap-4">
					<div class="flex items-center gap-1">
						<span class="w-6 h-6 flex shrink-0" set:html={getIconWithColor('location', '#ff9689')} />
						Florida, USA
					</div>
					<div class="flex items-center text-sm px-3 py-1 bg-black border border-(--color-skyBlue)/40 rounded-md">
						English
					</div>
				</div>
			</aside>
			<!-- Description Section -->
			<div class="flex flex-col items-start w-full md:w-2/3 gap-6 md:gap-8 md:p-4">
				<!-- Schedule a call Button -->
				<div class="cursor-pointer relative flex items-center pr-1 pl-3 py-1 gap-2 border-2 border-(--color-skyBlue)/40 hover:border-(--color-skyBlue) transition-colors duration-200 bg-black rounded-full">
					<span class="w-6 h-6 flex shrink-0" set:html={getIconWithColor('calendar', skyBlue)} />
					Schedule a call
					<div class="flex items-center justify-center p-1 border-2 border-(--color-timberwolf)/40 transition-colors duration-200 rounded-full">
						<span class="w-5 h-5 flex shrink-0" set:html={getIconWithColor('chevron-right', 'currentColor')} />
					</div>
				</div>
				<!-- Name, Title, and Social Links -->
				<div class="relative flex flex-col gap-3">
					<h1 class="about-title font-medium leading-none">
						Marlon Ausby II
					</h1>
					<h2 class="about-subtitle font-light text-(--color-gray)">
						Solutions Engineer
					</h2>
					<!-- Social Links -->
					<div class="flex flex-wrap gap-2 mt-2">
						<a href="/" class="social-button">
							<span class="w-4 h-4 flex shrink-0" set:html={getIconWithColor('github', skyBlue)} />
							GitHub
						</a>
						<a href="/" class="social-button">
							<span class="w-4 h-4 flex shrink-0" set:html={getIconWithColor('linkedin', skyBlue)} />
							LinkedIn
						</a>
						<a href="/" class="social-button">
							<span class="w-4 h-4 flex shrink-0" set:html={getIconWithColor('twitter', skyBlue)} />
							Twitter
						</a>
						<a href="/" class="social-button">
							<span class="w-4 h-4 flex shrink-0" set:html={getIconWithColor('instagram', skyBlue)} />
							Instagram
						</a>
					</div>
				</div>
				<!-- Summary -->
				<div class="flex flex-col mb-10">
					<p class="text-base sm:text-lg text-(--color-platinum) max-w-[65ch]">
						With 6+ years of experience building secure, data-driven systems in fintech and cloud environments.
						Specialized in payment processing, PCI-compliant architectures, large-scale data migrations, and fraud detection.
						Background in biomedical sciences brings a rigorous, analytical approach to designing reliable, scalable applications.
					</p>
				</div>
			</div>
		</div>
	</section>

	<!-- <FooterMenu /> -->
</MainLayout>

<style>
	.social-button {
		cursor: pointer;
		position: relative;
		display: flex;
		align-items: center;
		font-size: 0.875rem;
		line-height: 1.25rem;
		padding: 0.25rem 0.75rem;
		background-color: black;
		border: 2px solid color-mix(in srgb, var(--color-skyBlue) 20%, transparent);
		border-radius: 9999px;
		gap: 0.25rem;
		transition:
			border-color 200ms,
			color 200ms,
			background-color 200ms;
	}

	.social-button:hover {
		border-color: var(--color-skyBlue);
	}

	/* Profile picture: smaller on phones, grows on tablet+ */
	.profile-img {
		width: clamp(6rem, 8rem + 4vw, 11rem);
	}

	/* Fluid headings on About */
	.about-title {
		font-size: clamp(2rem, 1.4rem + 3vw, 4rem);
	}
	.about-subtitle {
		font-size: clamp(1.125rem, 0.9rem + 1.2vw, 2rem);
	}
	.skill-accordion {
		display: flex;
		flex-direction: column;
		width: 100%;
		padding-inline: 1rem;
		padding-block: 0.25rem;
		border-radius: 0.5rem;
		background-color: black;
		border: 2px solid color-mix(in srgb, var(--color-skyBlue) 40%, transparent);
		transition: border-color 200ms, color 200ms, background-color 200ms;
	}

	.skill-accordion:hover {
		border-color: var(--color-skyBlue);
	}

	.skill-tab {
		position: relative;
		display: flex;
		align-items: center;
		font-size: 0.875rem;
		line-height: 1.25rem;
		padding: 0.25rem 0.75rem;
		background-color: black;
		border: 1px solid color-mix(in srgb, var(--color-skyBlue) 20%, transparent);
		border-radius: 5px;
		gap: 0.3rem;
		transition: border-color 200ms, color 200ms, background-color 200ms;
	}

	.skill-bullet {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		margin-bottom: 1.5rem;
	}

	.sub-heading {
		font-size: 2.5em;
		font-weight: 400;
	}

	.sub-description {
		color: var(--color-gray);
	}
</style>