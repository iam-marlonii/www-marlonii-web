---
import '../styles/global.css';
import MainMenu from '../components/menus/MainMenu.astro';
import FooterMenu from '../components/menus/MainFooter.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<meta name="color-scheme" content="dark" />
		<meta name="theme-color" content="#00070d" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400..700&family=Geist:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
		<title>Marlon Ausby II</title>
	</head>
	<body>
		<div class="mesh-background"></div>
		<MainMenu currentPath={Astro.url.pathname} />
		<slot />
		<FooterMenu />
	</body>
</html>

<style is:global>
	html {
		margin: 0;
		background-color: #00070d;
		/* Prevent horizontal scroll caused by absolute children on very small viewports */
		overflow-x: hidden;
		/* Smoother resizing on Safari when toolbars hide/show */
		-webkit-text-size-adjust: 100%;
	}

	body {
		margin: 0;
		background: transparent;
		color: #ffffff;
		width: 100%;
		min-height: 100svh;
		font-family: 'Geist', monospace;
		/* Respect notches / rounded screens on phones in landscape */
		padding-left: env(safe-area-inset-left);
		padding-right: env(safe-area-inset-right);
	}

	/* Page-level horizontal rhythm.
	   - Stays fluid through tablet
	   - Caps content width on large displays so text doesn't stretch unreadably wide
	   - Centers content on ultrawide / 4K monitors */
	.page-shell {
		width: 100%;
		max-width: 1280px;
		margin-inline: auto;
		padding-inline: clamp(16px, 4vw, 32px);
	}

	@media (min-width: 1536px) {
		.page-shell {
			max-width: 1440px;
		}
	}

	@media (min-width: 1920px) {
		.page-shell {
			max-width: 1600px;
		}
	}
</style>